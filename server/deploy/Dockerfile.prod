# Production image: copies a pre-built linux/amd64 binary (no compilation on the
# resource-constrained server). Build the binary locally with build-binary.sh.
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata && adduser -D -u 10001 app
WORKDIR /app
COPY api /app/api
USER app
EXPOSE 8080
ENTRYPOINT ["/app/api"]
