# Copy to .env and fill in. NEVER commit the real .env.
APP_ENV=dev
HTTP_PORT=8080

# ---- Postgres (docker-compose reads POSTGRES_PASSWORD) ----
POSTGRES_PASSWORD=us_dev_password
# For running `go run` locally against the compose Postgres:
DATABASE_URL=postgres://us:us_dev_password@localhost:5432/us?sslmode=disable

# ---- Auth ----
# Generate: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_long_random_secret_value
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Sign in with Apple audiences (app bundle id, plus a Service ID if you add web).
APPLE_CLIENT_IDS=us.elbek.com

# ---- APNs (fill once the Apple Developer account is ready) ----
APNS_KEY_PATH=/app/secrets/AuthKey.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_TOPIC=us.elbek.com
APNS_PRODUCTION=false

# ---- CORS (comma-separated; * for dev) ----
CORS_ALLOWED_ORIGINS=*

# ---- Media storage & freemium quotas (bytes) ----
MEDIA_DIR=./media-data
FREE_STORAGE_BYTES=2147483648
PREMIUM_STORAGE_BYTES=32212254720
